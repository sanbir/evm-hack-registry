// File: contracts/AutoPooledTradingBot.sol


pragma solidity ^0.8.24;





contract AutoPooledTradingBot is AutomationCompatibleInterface, ReentrancyGuard {
    // Network Configuration
    enum Network { MAINNET, SEPOLIA }
    Network public currentNetwork;
    
    // Chainlink Price Feed
    AggregatorV3Interface internal priceFeed;
    mapping(Network => address) private priceFeedAddresses;

    // Emergency ban tracking
    mapping(address => uint256) public emergencyBanExpiry;
    uint256 public constant EMERGENCY_BAN_DURATION = 90 days;
    uint256 public constant EMERGENCY_PENALTY_BPS = 1000; // 10% penalty (1000 = 10%)

    // Pool Structure
    struct LiquidityPool {
        uint256 totalETH;
        uint256 totalShares;
        uint256 lastRebalanceTime;
    }
    LiquidityPool public tradingPool;
    
    // Trading Parameters
    struct TradeConfig {
        uint256 buyThreshold;
        uint256 sellThreshold;
        uint256 tradeSize;
    }
    TradeConfig public tradingParams = TradeConfig({
        buyThreshold: 1700 * 10**8,
        sellThreshold: 1900 * 10**8,
        tradeSize: 10
    });
    
    // User Accounts
    struct User {
        uint256 shares;
        uint256 referralShares;
        address referrer;
        uint256 lastDepositTime;
        uint256 totalInvested;
        uint256 totalWithdrawn;
        uint256 referralEarnings;
        uint256 referralCount;
        uint256 referralTier; // 0-3 for different tiers
    }
    mapping(address => User) public users;
    
    // Referral Tracking
    mapping(address => uint256) public referralCounts;
    mapping(address => uint256) public activeReferrals;
    mapping(address => uint256) public totalReferredAmount;
    
    // Referral Tiers (0-3)
    struct Tier {
        uint256 percentage; // Basis points (100 = 1%)
        uint256 minVolume;  // Minimum ETH volume required
    }
    Tier[4] public tiers;
    
    // Constants
    uint256 public constant PERFORMANCE_FEE = 10; // 1%
    uint256 public constant UPKEEP_INTERVAL = 1 days;
    uint256 public constant WITHDRAWAL_FEE = 5; // 0.5%
    uint256 public constant MIN_DEPOSIT = 0.01 ether;
    uint256 public constant REFERRAL_LOCK_PERIOD = 7 days;
    uint256 public constant REFERRAL_BONUS_BASE = 50; // 5% base bonus
    uint256 public constant REFERRAL_PROFIT_SHARE = 100; // 10% of profits
    uint256 public constant MAX_TRADE_SIZE = 20; // 20% of pool
    
    // Admin
    address public owner;
    address public feeCollector;
    uint256 public coreLiquidity;
    bool public tradingPaused;
    bool public emergencyStop;
    uint256 public paramChangeDelay = 2 days;
    mapping(bytes32 => uint256) public changeRequests;
    
    // Events
    event AutoTradeExecuted(bool isBuy, uint256 amount, uint256 price, bytes32 tradeHash);
    event ProfitDistributed(uint256 amount);
    event NetworkChanged(Network newNetwork);
    event ReferralEarned(address indexed referrer, address referee, uint256 amount);
    event ReferralAdded(address indexed referrer, address indexed referee, uint256 amount);
    event Deposited(address indexed user, uint256 amount, address indexed referrer, uint256 shares);
    event ReferralWithdrawn(address indexed referrer, uint256 amount);
    event InvestmentWithdrawn(address indexed user, uint256 ethAmount, uint256 fee);
    event TradingPaused(bool paused);
    event EmergencyWithdraw(address indexed user, uint256 amount);
    event TierUpgraded(address indexed user, uint256 newTier);
    event TradingParamsUpdated(uint256 buy, uint256 sell, uint256 size);
    event EmergencyStopTriggered(bool stopped);
    event ParamChangeRequested(bytes32 paramHash);
    event ParamChangeExecuted(bytes32 paramHash);
    event CoreLiquidityUpdated(uint256 amount);
    event FeeCollectorUpdated(address newCollector);
    event TradeNotification(address indexed user, string message);
    event ReferralStatsUpdated(address indexed referrer, uint256 totalReferrals, uint256 activeReferrals, uint256 totalEarned);
    event EmergencyUserWithdrawal(
        address indexed user,
        uint256 liquidityWithdrawn,
        uint256 referralWithdrawn,
        uint256 penalty,
        uint256 banUntil
    );

    constructor(Network _network) {
        owner = msg.sender;
        tradingPaused = false;
        emergencyStop = false;
        
        // Initialize tiers
        tiers[0] = Tier(500, 0);    // 5% for tier 0 (default)
        tiers[1] = Tier(700, 5 ether);  // 7% for tier 1
        tiers[2] = Tier(1000, 20 ether); // 10% for tier 2
        tiers[3] = Tier(1500, 50 ether); // 15% for tier 3
        
        // Set up price feeds
        priceFeedAddresses[Network.MAINNET] = 0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419;
        priceFeedAddresses[Network.SEPOLIA] = 0x694AA1769357215DE4FAC081bf1f309aDC325306;
        _setNetwork(_network);
    }

    // ========== PRIVATE FUNCTIONS ========== //
    function _calculateShares(uint256 ethAmount) private view returns (uint256) {
        if (tradingPool.totalETH == 0) {
            return ethAmount;
        }
        return (ethAmount * tradingPool.totalShares) / tradingPool.totalETH;
    }

    function _checkTierUpgrade(address userAddress) private {
        User storage user = users[userAddress];
        uint256 invested = user.totalInvested;
        
        if (invested >= tiers[3].minVolume && user.referralTier < 3) {
            user.referralTier = 3;
            emit TierUpgraded(userAddress, 3);
        } else if (invested >= tiers[2].minVolume && user.referralTier < 2) {
            user.referralTier = 2;
            emit TierUpgraded(userAddress, 2);
        } else if (invested >= tiers[1].minVolume && user.referralTier < 1) {
            user.referralTier = 1;
            emit TierUpgraded(userAddress, 1);
        }
    }

    function _handleReferral(address referrer, uint256 shares, User storage user) private {
        if (referrer != address(0)) {
            if (user.referrer == address(0) && referrer != msg.sender) {
                user.referrer = referrer;
                users[referrer].referralCount++;
                referralCounts[referrer]++;
                activeReferrals[referrer]++;
                totalReferredAmount[referrer] += msg.value;
                
                uint256 tierBonus = tiers[users[referrer].referralTier].percentage;
                uint256 referralBonus = (shares * tierBonus) / 10000;
                
                user.referralShares += referralBonus;
                users[referrer].referralEarnings += referralBonus;
                
                emit ReferralAdded(referrer, msg.sender, msg.value);
                emit ReferralEarned(referrer, msg.sender, referralBonus);
                _updateReferralStats(referrer);
            }
        }
    }

    function _distributeProfits(uint256 profit) private {
        uint256 fee = (profit * PERFORMANCE_FEE) / 1000;
        uint256 referralRewards = (profit * REFERRAL_PROFIT_SHARE) / 1000;
        
        tradingPool.totalETH -= (fee + referralRewards);
        payable(owner).transfer(fee);
        
        if (tradingPool.totalShares > 0) {
            tradingPool.totalShares += referralRewards;
        }
        emit ProfitDistributed(profit);
    }

    function _setNetwork(Network _network) private {
        currentNetwork = _network;
        priceFeed = AggregatorV3Interface(priceFeedAddresses[_network]);
        emit NetworkChanged(_network);
    }

    function _updateReferralStats(address referrer) private {
        emit ReferralStatsUpdated(
            referrer,
            users[referrer].referralCount,
            activeReferrals[referrer],
            users[referrer].referralEarnings
        );
    }

    // ========== PUBLIC FUNCTIONS ========== //
    function deposit(address referrer) external payable notBanned nonReentrant {
        require(!tradingPaused, "Deposits paused");
        require(!emergencyStop, "Emergency stop active");
        require(msg.value >= MIN_DEPOSIT, "Deposit too small");
        
        uint256 shares = _calculateShares(msg.value);
        tradingPool.totalETH += msg.value;
        tradingPool.totalShares += shares;
        
        User storage user = users[msg.sender];
        user.shares += shares;
        user.lastDepositTime = block.timestamp;
        user.totalInvested += msg.value;
        
        if (referrer != address(0)) {
            _handleReferral(referrer, shares, user);
            emit TradeNotification(msg.sender, "New deposit with referral");
        } else {
            emit TradeNotification(msg.sender, "New deposit without referral");
        }
        
        _checkTierUpgrade(msg.sender);
        emit Deposited(msg.sender, msg.value, user.referrer, shares);
    }

    function withdrawInvestment(uint256 minExpected) external notBanned nonReentrant {
        require(!emergencyStop, "Emergency stop active");
        require(feeCollector != address(0), "Fee collector not set");
        
        User storage user = users[msg.sender];
        uint256 earnings = user.totalInvested - user.totalWithdrawn;
        require(earnings > 0, "No earnings available");
        
        uint256 withdrawableAmount = (earnings * 90) / 100;
        require(withdrawableAmount <= address(this).balance - coreLiquidity, 
               "Insufficient available liquidity");
        
        uint256 fee = (withdrawableAmount * WITHDRAWAL_FEE) / 1000;
        uint256 amountAfterFee = withdrawableAmount - fee;
        
        require(amountAfterFee >= minExpected, "Slippage too high");
        
        user.totalWithdrawn += amountAfterFee;
        
        payable(msg.sender).transfer(amountAfterFee);
        payable(feeCollector).transfer(fee);
        
        emit InvestmentWithdrawn(msg.sender, amountAfterFee, fee);
        emit TradeNotification(msg.sender, string(abi.encodePacked(
            "Withdrawal completed: ", 
            Strings.toString(amountAfterFee / 1e16), 
            " ETH"
        )));
    }

    function withdrawReferralEarnings() external notBanned nonReentrant {
        require(!emergencyStop, "Emergency stop active");
        User storage user = users[msg.sender];
        require(user.referralEarnings > 0, "No earnings");
        
        uint256 ethAmount = (user.referralEarnings * tradingPool.totalETH) / tradingPool.totalShares;
        
        tradingPool.totalShares -= user.referralEarnings;
        tradingPool.totalETH -= ethAmount;
        user.referralEarnings = 0;
        
        payable(msg.sender).transfer(ethAmount);
        emit ReferralWithdrawn(msg.sender, ethAmount);
        emit TradeNotification(msg.sender, string(abi.encodePacked(
    "Referral earnings withdrawn: ", 
    Strings.toString(ethAmount / 1e16), 
    " ETH"
       )));
        _updateReferralStats(msg.sender);
    }

    function emergencyWithdrawAll() external nonReentrant {
        require(emergencyBanExpiry[msg.sender] < block.timestamp, "Account is banned");
        
        User storage user = users[msg.sender];
        require(user.shares > 0 || user.referralEarnings > 0, "No funds to withdraw");

        // Calculate liquidity portion
        uint256 liquidityETH = 0;
        uint256 penalty = 0;
        
        if (user.shares > 0) {
            liquidityETH = (user.shares * tradingPool.totalETH) / tradingPool.totalShares;
            penalty = (liquidityETH * EMERGENCY_PENALTY_BPS) / 10000;
            
            // Update pool and user
            tradingPool.totalETH -= liquidityETH;
            tradingPool.totalShares -= user.shares;
            user.shares = 0;
            user.totalWithdrawn += (liquidityETH - penalty);
        }

        // Calculate referral portion
        uint256 referralETH = 0;
        if (user.referralEarnings > 0) {
            referralETH = (user.referralEarnings * tradingPool.totalETH) / tradingPool.totalShares;
            tradingPool.totalShares -= user.referralEarnings;
            tradingPool.totalETH -= referralETH;
            user.referralEarnings = 0;
        }

        // Apply ban
        uint256 banUntil = block.timestamp + EMERGENCY_BAN_DURATION;
        emergencyBanExpiry[msg.sender] = banUntil;

        // Transfer funds
        uint256 totalToSend = (liquidityETH - penalty) + referralETH;
        payable(msg.sender).transfer(totalToSend);
        
        if (penalty > 0) {
            payable(feeCollector).transfer(penalty);
        }

        emit EmergencyUserWithdrawal(
            msg.sender,
            liquidityETH,
            referralETH,
            penalty,
            banUntil
        );
    }

    // ========== MODIFIERS ========== //
    modifier notBanned() {
        require(emergencyBanExpiry[msg.sender] < block.timestamp, "Account is banned");
        _;
    }

    modifier onlyOwner() {
        require(msg.sender == owner, "Unauthorized");
        _;
    }

    // ========== ADMIN FUNCTIONS ========== //
    function setCoreLiquidity(uint256 amount) external onlyOwner {
        require(amount <= address(this).balance, "Amount exceeds balance");
        coreLiquidity = amount;
        emit CoreLiquidityUpdated(amount);
    }

    function setFeeCollector(address _feeCollector) external onlyOwner {
        require(_feeCollector != address(0), "Invalid address");
        feeCollector = _feeCollector;
        emit FeeCollectorUpdated(_feeCollector);
    }

    function requestTradingParamsChange(uint256 buy, uint256 sell, uint256 size) external onlyOwner {
        require(buy < sell, "Invalid thresholds");
        require(size > 0 && size <= MAX_TRADE_SIZE, "Invalid size");
        
        bytes32 paramHash = keccak256(abi.encodePacked(buy, sell, size));
        changeRequests[paramHash] = block.timestamp;
        emit ParamChangeRequested(paramHash);
    }

    function executeTradingParamsChange(uint256 buy, uint256 sell, uint256 size) external onlyOwner {
        bytes32 paramHash = keccak256(abi.encodePacked(buy, sell, size));
        require(changeRequests[paramHash] > 0, "No pending change");
        require(block.timestamp >= changeRequests[paramHash] + paramChangeDelay, "Delay not passed");
        
        tradingParams = TradeConfig(buy, sell, size);
        delete changeRequests[paramHash];
        emit TradingParamsUpdated(buy, sell, size);
        emit ParamChangeExecuted(paramHash);
    }

    function setNetwork(Network _network) external onlyOwner {
        _setNetwork(_network);
    }

    function pauseTrading(bool pause) external onlyOwner {
        tradingPaused = pause;
        emit TradingPaused(pause);
    }

    function triggerEmergencyStop(bool stop) external onlyOwner {
        emergencyStop = stop;
        emit EmergencyStopTriggered(stop);
    }

    function emergencyWithdraw() external onlyOwner {
        require(emergencyStop, "Emergency stop not active");
        uint256 balance = address(this).balance;
        payable(owner).transfer(balance);
        emit EmergencyWithdraw(owner, balance);
    }

    // ========== CHAINLINK AUTOMATION ========== //
    function checkUpkeep(bytes calldata) external view override returns (bool upkeepNeeded, bytes memory) {
        if (tradingPaused || emergencyStop) return (false, "");
        
        int currentPrice = getLatestPrice();
        bool timePassed = (block.timestamp - tradingPool.lastRebalanceTime) > UPKEEP_INTERVAL;
        
        upkeepNeeded = (
            (currentPrice < int(tradingParams.buyThreshold) || 
            currentPrice > int(tradingParams.sellThreshold))
            && timePassed
        );
        return (upkeepNeeded, "");
    }

    function performUpkeep(bytes calldata) external override {
        require(!tradingPaused, "Trading is paused");
        require(!emergencyStop, "Emergency stop active");
        require((block.timestamp - tradingPool.lastRebalanceTime) > UPKEEP_INTERVAL, "Too soon");
        
        (, int currentPrice,,,) = priceFeed.latestRoundData();
        bool shouldBuy = currentPrice < int(tradingParams.buyThreshold);
        uint256 tradeAmount = (tradingPool.totalETH * tradingParams.tradeSize) / 100;
        
        require(tradeAmount > 0, "Invalid trade amount");
        require(tradeAmount <= (tradingPool.totalETH * MAX_TRADE_SIZE) / 100, "Trade too large");
        
        uint256 profit = (tradeAmount * 5) / 100;
        
        if (shouldBuy) {
            tradingPool.totalETH -= tradeAmount;
            tradingPool.totalETH += profit;
        } else {
            tradingPool.totalETH += tradeAmount + profit;
        }
        
        bytes32 tradeHash = keccak256(abi.encodePacked(block.timestamp, tradeAmount));
        tradingPool.lastRebalanceTime = block.timestamp;
        _distributeProfits(profit);
        
        emit AutoTradeExecuted(shouldBuy, tradeAmount, uint256(currentPrice), tradeHash);
    }

    // ========== VIEW FUNCTIONS ========== //
    function getLatestPrice() public view returns (int) {
        (, int price,,,) = priceFeed.latestRoundData();
        return price;
    }

    function getUserStats(address user) external view returns (
        uint256 shares,
        uint256 referralShares,
        address referrer,
        uint256 referralEarnings,
        uint256 referralCount,
        uint256 totalInvested,
        uint256 totalWithdrawn,
        uint256 referralTier
    ) {
        User storage u = users[user];
        return (
            u.shares,
            u.referralShares,
            u.referrer,
            u.referralEarnings,
            u.referralCount,
            u.totalInvested,
            u.totalWithdrawn,
            u.referralTier
        );
    }

    function getReferralInfo(address user) external view returns (
        uint256 tier,
        uint256 percentage,
        uint256 earnings,
        uint256 count,
        uint256 nextTierVolume
    ) {
        User storage u = users[user];
        tier = u.referralTier;
        percentage = tiers[tier].percentage;
        earnings = u.referralEarnings;
        count = u.referralCount;
        
        if (tier < 3) {
            nextTierVolume = tiers[tier + 1].minVolume > u.totalInvested 
                ? tiers[tier + 1].minVolume - u.totalInvested 
                : 0;
        } else {
            nextTierVolume = 0;
        }
    }
    
    receive() external payable {
        revert("Use deposit() function");
    }
}