/// @title ElevateFi Token (EFI) with 5% Sell Tax & Auto‐Liquidity
/// @notice ERC20 token that applies a 5% fee on sells, auto-adds liquidity, and supports mint/burn roles
contract EFI is ERC20, AccessControl {

    /// @dev Role allowed to mint EFI by the system smart contracts only in algorithmic controlled manner.
    bytes32 public constant POLICY_ROLE           = keccak256("POLICY_ROLE");

    IUniswapV2Router02 public router;
    IERC20             public  dai;
    IUniswapV2Pair     public  mainPair;

    uint256 public constant SELL_TAX_PCT = 5;  
    uint256 public constant LIQ_PCT      = 1;  
    uint256 public constant MKT_PCT      = 2;  
    uint256 public constant CRT_PCT      = 2;  

    address public marketingWallet;
    address public creatorWallet;
    address public liquidityWallet;

    event LiquidityThresholdUpdated(uint256 newThreshold);
    event SwapAndLiquify(uint256 tokensSwapped, uint256 daiReceived, uint256 tokensIntoLiquidity);
    event PairUpdated(address pairAddress, address router, address dai);
    event WalletContractsUpdated(address marketingWallet, address creatorWallet, address liquidityWallet);


    /// @param _stakingContract Address of the staking contract (allowed to call burnFromStakingContract)
    /// @param admin            Address to receive DEFAULT_ADMIN_ROLE 
    /// @param _router          UniswapV2Router02 address for swaps/liquidity
    /// @param _dai             DAI token address for pairing
    /// @param _marketingWallet Address receiving marketing fee portion
    /// @dev Mints initial supply to admin and sets up roles & immutable parameters
    constructor(
        address _stakingContract,
        address admin,
        address _router,
        address _dai,
        address _marketingWallet
    ) ERC20("ElevateFi", "EFI") {
        require(admin               != address(0)
             && _stakingContract    != address(0)
             && _router             != address(0)
             && _dai                != address(0)
             && _marketingWallet    != address(0),
             "EFI: zero address"
        );

        _mint(admin, 75_000 * 10**decimals());

        _grantRole(DEFAULT_ADMIN_ROLE, admin);
        _grantRole(POLICY_ROLE, _stakingContract);

        router            = IUniswapV2Router02(_router);
        dai               = IERC20(_dai);
        marketingWallet   = _marketingWallet;
        creatorWallet     = msg.sender;
    }

    /// @notice Mint new EFI tokens to an address
    /// @param to     Recipient address
    /// @param amount Amount of EFI to mint
    /// @dev Only callable by staking contract
    function mint(address to, uint256 amount) external onlyRole(POLICY_ROLE) {
        _mint(to, amount);
    }

    /// @notice Burn EFI from the caller’s balance
    /// @param amount Amount of EFI to burn
    function burn(uint256 amount) external {
        _burn(_msgSender(), amount);
    }

    /// @notice Burn EFI from another address using allowance
    /// @param from   Address whose tokens are burned
    /// @param amount Amount of EFI to burn
    function burnFrom(address from, uint256 amount) external {
        _spendAllowance(from, _msgSender(), amount);
        _burn(from, amount);
    }

    /// @notice Burn EFI from another address without allowance
    /// @param from   Address whose tokens are burned
    /// @param amount Amount of EFI to burn
    /// @dev Only callable by the staking contract; bypasses allowance for UX
    function burnFromStakingContract(address from, uint256 amount) external onlyRole(POLICY_ROLE) {
        _burn(from, amount);
    }

    /// @notice Transfer EFI with sell-tax applied on sells to the mainPair
    /// @param to     Recipient address
    /// @param amount Amount of EFI to transfer
    /// @return       True on success
    /// @dev Overrides ERC20.transfer to apply tax logic
    function transfer(address to, uint256 amount) public override returns (bool) {
        _taxedTransfer(_msgSender(), to, amount);
        return true;
    }

    /// @notice Transfer EFI using allowance with sell-tax logic on sells
    /// @param from   Address tokens are transferred from
    /// @param to     Recipient address
    /// @param amount Amount of EFI to transfer
    /// @return       True on success
    /// @dev Overrides ERC20.transferFrom to apply tax logic
    function transferFrom(address from, address to, uint256 amount) public override returns (bool) {
        // handle allowance
        _spendAllowance(from, _msgSender(), amount);
        _taxedTransfer(from, to, amount);
        return true;
    }

    /// @dev Core transfer that applies a 5% tax on sells to the pair, distributes fees, and triggers auto-liquidity
    /// @param from   Sender address
    /// @param to     Recipient address
    /// @param amount Amount of EFI to transfer
    function _taxedTransfer(address from, address to, uint256 amount) internal {

        // detect sell
        if (to == address(mainPair)) {
            uint256 tax    = amount * SELL_TAX_PCT / 100;
            uint256 liqAmt = tax * LIQ_PCT / SELL_TAX_PCT;
            uint256 mktAmt = tax * MKT_PCT / SELL_TAX_PCT;
            uint256 crtAmt = tax - liqAmt - mktAmt;
            uint256 net    = amount - tax;

            // distribute fees
            super._transfer(from, marketingWallet, mktAmt);
            super._transfer(from, creatorWallet,   crtAmt);
            super._transfer(from, liquidityWallet,   liqAmt);
            super._transfer(from, to,              net);

        } else {
            // no tax
            super._transfer(from, to, amount);
        }
    }


    /* ========== ADMIN ========== */

    /// @notice Set the Uniswap EFI–DAI pair contract address
    /// @param daiEfiPairAddress Address of the new pair
    /// @dev Only callable by DEFAULT_ADMIN_ROLE
    function setPairData(address daiEfiPairAddress, address _router, address _dai) external onlyRole(DEFAULT_ADMIN_ROLE) {
        mainPair          = IUniswapV2Pair(daiEfiPairAddress);
        router            = IUniswapV2Router02(_router);
        dai               = IERC20(_dai);
        emit PairUpdated(daiEfiPairAddress, _router, _dai);
    }

    /// @notice Admin can update the staking contract address
    /// @param _marketingWallet The new marketing wallet
    /// @param _creatorWallet The new creator wallet
    function setContracts(address _marketingWallet, address _creatorWallet, address _liquidityWallet) external onlyRole(DEFAULT_ADMIN_ROLE) {
        
        require(_marketingWallet != address(0), "EFI: zero address");
        require(_creatorWallet != address(0), "EFI: zero address");
        require(_liquidityWallet != address(0), "EFI: zero address");
        
        marketingWallet = _marketingWallet;
        creatorWallet = _creatorWallet;
        liquidityWallet = _liquidityWallet;

        emit WalletContractsUpdated(_marketingWallet, _creatorWallet, _liquidityWallet);
    }
    
}