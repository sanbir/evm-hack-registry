// File: nostrs/ILotteryTicket.sol


pragma solidity 0.8.20;

interface ILotteryTicket is IERC20{
    function mint(address _to, uint256 _amount) external  returns (bool);
}

// File: nostrs/WhiteList.sol


pragma solidity 0.8.20;


abstract contract WhiteList is Ownable {

    function getWhiteListStatus(address _maker) external view returns (bool) {
        return isWhiteListed[_maker];
    }

    mapping (address => bool) public isWhiteListed;

    function addWhiteList (address _user) public onlyOwner {
        isWhiteListed[_user] = true;
        emit AddedWhiteList(_user);
    }

    function removeWhiteList (address _clearedUser) public onlyOwner {
        isWhiteListed[_clearedUser] = false;
        emit RemovedWhiteList(_clearedUser);
    }

    event AddedWhiteList(address indexed _user);

    event RemovedWhiteList(address indexed _user);

}
// File: nostrs/LotteryTicketSwap50.sol


pragma solidity 0.8.20;








contract LotteryTicketSwap50 is WhiteList {
    //路由合约
    address internal constant ROUTER_ADDRESS = 0x09923035c264940b5db3682e8aF5D2499Ee6Eb40;
    address internal constant FACTORY_ADDRESS = 0x850D2e6c403EFa88bC5B604c278F3A3cFa0EA1cB;
    //代币合约tokenA_USDT
    address public tokenUSDT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913;   
    //代币合约tokenB_NATA
    address public tokenNATA=0xb39392F4b6D92a6BD560Ed260C2c488081aAB8E9;   
    //奖券合约
    address public ticket=0xF9260Bb78d16286270e123642ca3DE1F2289783b; 
    // 2. 获取交易对合约地址
    address public pairAddress = IUniswapV2Factory(FACTORY_ADDRESS).getPair(tokenUSDT, tokenNATA);
    // 每次缴款最小金额
    uint256 public constant MIN_DEPOSIT = 50 * 10 ** 6;
    IERC20  coinUsdt = IERC20(tokenUSDT); 
    IERC20   coinNata = IERC20(tokenNATA);
    ILotteryTicket  coinTicket = ILotteryTicket(ticket);
    uint112  public reserveUSDT;
    uint112  public reserveNATA;
    uint public amountBDesired;

    function setTicket(address _ticket) external onlyOwner{
        ticket=_ticket;
    }

    function setTokenNATA(address _tokenNATA) external onlyOwner{
        tokenNATA=_tokenNATA;
    }   
    function setTokenUSDT(address _tokenUSDT) external onlyOwner{
        tokenUSDT=_tokenUSDT;
    }
    bool public flag1=false;
    function setFlag1(bool _flag1) external onlyOwner{
        flag1=_flag1;
    }
    function transferToken(uint  amount) public returns (bool) {
        IUniswapV2Router02  swapRouter = IUniswapV2Router02(ROUTER_ADDRESS);
        
        require(amount > 0, "Amount must more than 0 USDT");
        require(amount % MIN_DEPOSIT == 0, "Amount must be a multiple of 50 USDT");
        uint allowmount=   coinUsdt.allowance(msg.sender,address(this));
        require(allowmount>=amount, "Insufficient authorization limit");
        
        // 转账 USDT 到合约
        require(coinUsdt.transferFrom(msg.sender,address(this),amount), "USDT transfer failed");

        uint ticket_count=amount/MIN_DEPOSIT;
        
        require(coinTicket.mint(msg.sender,ticket_count * 10 ** 6), "Ticket mint failed");

        uint amountIn=amount*50/100;
        address[] memory path = new address[](2);
            path[0] = tokenUSDT;
            path[1] = tokenNATA;
        coinUsdt.approve(ROUTER_ADDRESS, amount);
        swapRouter.swapExactTokensForTokensSupportingFeeOnTransferTokens(
            amountIn,
            1,
            path,
            address(this),
            block.timestamp+600
        );
   
        uint amountADesired=amountIn*997/1000;
        // 批准 Uniswap 路由合约转移 U 和 NATA 代币用于添加流动性
        coinUsdt.approve(ROUTER_ADDRESS, amount);
        coinNata.approve(ROUTER_ADDRESS, coinNata.totalSupply());

        // 3. 调用Pair合约获取储备数据
        address token0 = IUniswapV2Pair(pairAddress).token0();


        if(token0==tokenUSDT){
            ( reserveUSDT,  reserveNATA,) = IUniswapV2Pair(pairAddress).getReserves();
        }else {
             (reserveNATA, reserveUSDT,) = IUniswapV2Pair(pairAddress).getReserves();
        }
       
        //uint 
        amountBDesired = (amountADesired * reserveNATA) / reserveUSDT;
        if(flag1){
            swapRouter.addLiquidity(
                tokenUSDT, 
                tokenNATA, 
                amountADesired, 
                amountBDesired, 
                1, 
                1, 
                address(this),
                block.timestamp+600
                );
        }

        return true;
    }
 


    function DestructionOfLotteryTickets(uint  _amountTickets) public returns(bool){
        IUniswapV2Router02  swapRouter = IUniswapV2Router02(ROUTER_ADDRESS);
        
        // 保证奖券是整个
        uint256   MIN_TICKET = 1 * 10 ** 6;
        require(_amountTickets > 0, "Amount must more than 0 TICKET");
        require(_amountTickets % MIN_TICKET == 0, "Amount must be a multiple of 1 Ticket");
        uint allowmount=   coinTicket.allowance(msg.sender,address(this));
        require(allowmount>=_amountTickets, "Insufficient authorization limit");
        // 销毁奖券，转移到0地址
        address   deadAddress=0x000000000000000000000000000000000000dEaD;
        require(coinTicket.transferFrom(msg.sender,deadAddress,_amountTickets), "Ticket transfer failed");
        

        //计算机需要LP的个数
        uint ticket_count=_amountTickets/MIN_TICKET;
        uint amountUSDTALL=ticket_count*MIN_DEPOSIT;
        uint amountUSDT=amountUSDTALL/2*997/1000;
        // 3. 调用Pair合约获取储备数据
        // (uint256 reserveUSDT,,) = IUniswapV2Pair(pairAddress).getReserves();
        address token0 = IUniswapV2Pair(pairAddress).token0();

        if(token0==tokenUSDT){
            ( reserveUSDT,  reserveNATA,) = IUniswapV2Pair(pairAddress).getReserves();
        }else {
             (reserveNATA, reserveUSDT,) = IUniswapV2Pair(pairAddress).getReserves();
        }
       
        uint256 totalSupplyLP=IERC20(pairAddress).totalSupply();
        uint liquidity = (amountUSDT * totalSupplyLP) / reserveUSDT;
        
        IERC20(pairAddress).approve(ROUTER_ADDRESS, liquidity);
        if(isWhiteListed[msg.sender]){
            uint liquidityALL = (amountUSDT * totalSupplyLP) / reserveUSDT;
            IERC20(pairAddress).transfer(msg.sender,liquidityALL);
        }else{
            // 销毁 LP，转移到 0地址
            (, uint amountNATAout) = swapRouter.removeLiquidity(
                tokenUSDT, 
                tokenNATA, 
                liquidity, 
                1,
                1,
                address(this),
                block.timestamp+600
            );
            address[] memory path = new address[](2);
                path[0] = tokenNATA;
                path[1] = tokenUSDT;
            uint amountOut= amountUSDTALL*994/1000-amountUSDT;
            uint[] memory amounts = swapRouter.getAmountsOut(amountOut, path);   
            uint amountInMax;
            if(amounts[0]>amountNATAout) {
                amountInMax=amounts[0];
            }else {
                amountInMax=amountNATAout;
            }
            swapRouter.swapTokensForExactTokens(
                amountOut, 
                amountInMax, 
                path, 
                address(this), 
                block.timestamp+600
            );
            coinUsdt.transfer(msg.sender,amountUSDTALL*994/1000);

        }
       
    return true;
    }

    function extractToken(address coinAddr,uint256 amount) public  onlyOwner{
        require(coinAddr==tokenUSDT||coinAddr==tokenNATA,"Invalid coinAddr");
        IERC20(coinAddr).transfer(msg.sender,amount);
    }

}